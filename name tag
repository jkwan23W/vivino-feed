<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>7cm Wine Dinner Name Tags - Printable</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        /* 打印专用设置 */
        @page {
            size: A4;
            margin: 0mm; 
        }

        @media print {
            .no-print { display: none !important; }
            body { 
                margin: 0 !important; 
                padding: 0 !important;
                background: white !important; 
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-scheme: light;
            }
            .page-container {
                display: block !important;
                width: 210mm; /* A4 Width */
                padding: 10mm;
            }
            .grid-container {
                display: grid !important;
                grid-template-columns: 70mm 70mm !important; /* 强制两列 7cm */
                gap: 0 !important;
                justify-content: center;
            }
            .name-tag-tent {
                border: 0.1mm solid #e0e0e0 !important;
                box-shadow: none !important;
                break-inside: avoid;
                page-break-inside: avoid;
                background-color: white !important;
                visibility: visible !important;
                display: flex !important;
            }
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #f3f4f6;
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(2, 7cm);
            gap: 12px;
            padding: 20px;
            justify-content: center;
        }

        /* 尺寸: 7cm x 7cm (折叠后 3.5cm 高) */
        .name-tag-tent {
            width: 7cm;
            height: 7cm;
            background: white;
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .fold-line {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            border-top: 1px dashed #e5e5e5;
            z-index: 10;
        }

        .tent-face-blank {
            height: 3.5cm;
            background-color: #fff;
        }

        .tent-face-name {
            height: 3.5cm;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            padding: 2mm;
        }

        .guest-name {
            font-family: 'Great Vibes', cursive;
            font-size: 26pt;
            color: #1a1a1a;
            text-align: center;
            line-height: 1.1;
        }

        .footer-logo {
            position: absolute;
            bottom: 2mm;
            font-size: 5pt;
            color: #bbb;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-weight: 400;
        }

        .ai-panel {
            max-width: 600px;
            margin: 1rem auto;
            background: #fdf2f8;
            border: 1px solid #fbcfe8;
            border-radius: 0.75rem;
            padding: 1rem;
            text-align: left;
        }
    </style>
</head>
<body>

    <div class="no-print p-8 bg-white border-b sticky top-0 z-50 shadow-md text-center">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Vinosophy 晚宴名牌 (7cm x 7cm)</h1>
        <p class="text-gray-600 mb-6 font-medium">
            💡 <b>修复提示：</b>如果预览仍为空，请确保在打印窗口勾选了 <b>“背景图形 (Background Graphics)”</b>。
        </p>
        
        <div class="flex justify-center gap-4 mb-4">
            <button onclick="window.print()" class="bg-rose-900 text-white px-10 py-3 rounded-full font-bold hover:bg-rose-800 transition shadow-lg transform hover:scale-105">
                🖨️ 立即打印 / 保存 PDF
            </button>
            <button onclick="getAIDinnerPlan()" id="ai-btn" class="bg-indigo-600 text-white px-10 py-3 rounded-full font-bold hover:bg-indigo-500 transition shadow-lg flex items-center gap-2">
                ✨ Gemini 晚宴管家
            </button>
        </div>

        <div id="ai-result" class="hidden ai-panel">
            <div id="ai-status" class="text-rose-700 font-bold text-sm mb-1 uppercase tracking-wider"></div>
            <div id="ai-content" class="text-gray-800 text-sm italic leading-relaxed whitespace-pre-wrap"></div>
        </div>
    </div>

    <div class="page-container">
        <div id="tags-container" class="grid-container">
            <!-- JavaScript 自动生成内容 -->
        </div>
    </div>

    <script>
        const apiKey = ""; 
        const guests = [
            "Ming Fang", "Shelley Hon", "Angel Wei", "Shirley Chiu", 
            "Pierre", "Peter Wu", "Dora Kam", "Mr Xing", 
            "Mr Lai", "YeoJun Jo", "Karen Kwan", "Ken Lai", 
            "Vanessa Lai", "Agnes Hon", "Lee Robinson", "Nicolas", 
            "Colin Zhong", "Bernard Lim"
        ];

        const container = document.getElementById('tags-container');
        guests.forEach(name => {
            const tag = document.createElement('div');
            tag.className = 'name-tag-tent';
            tag.innerHTML = `
                <div class="fold-line"></div>
                <div class="tent-face-blank"></div>
                <div class="tent-face-name">
                    <div class="guest-name">${name}</div>
                    <div class="footer-logo">Vinosophy Selection</div>
                </div>
            `;
            container.appendChild(tag);
        });

        async function getAIDinnerPlan() {
            const btn = document.getElementById('ai-btn');
            const resultDiv = document.getElementById('ai-result');
            const statusDiv = document.getElementById('ai-status');
            const contentDiv = document.getElementById('ai-content');

            btn.disabled = true;
            resultDiv.classList.remove('hidden');
            statusDiv.textContent = "正在联想优雅的话题...";
            
            const prompt = `你是一位葡萄酒管家。请为 Vinosophy 晚宴提供开场白和话题。嘉宾：${guests.join(", ")}。`;
            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
                });
                const data = await response.json();
                statusDiv.textContent = "✨ 建议：";
                contentDiv.textContent = data.candidates[0].content.parts[0].text;
            } catch (err) {
                contentDiv.textContent = "AI 暂时不可用，请直接打印。";
            } finally {
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
